<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Custom Pet Adventure</title>
  <style>
    body {
      margin: 0;
      background: #0b1120;
      color: #eef;
      font-family: Arial, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      min-height: 100vh;
      padding: 14px;
    }
    h1 {
      margin: 0;
      font-size: 28px;
    }
    #wrapper {
      display: flex;
      gap: 14px;
      max-width: 980px;
      width: 100%;
      flex-wrap: wrap;
      justify-content: center;
    }
    canvas {
      border: 4px solid #405070;
      background: white;
      width: 800px;
      height: 500px;
      image-rendering: pixelated;
    }
    .panel {
      background: rgba(20, 35, 60, 0.92);
      border: 1px solid #446;
      border-radius: 12px;
      padding: 12px 14px;
      min-width: 240px;
      box-sizing: border-box;
    }
    .panel strong {
      display: block;
      margin-bottom: 8px;
      font-size: 15px;
      letter-spacing: 0.03em;
    }
    .button-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    button {
      border: 1px solid #657;
      background: #2e486b;
      color: #eef;
      padding: 10px 14px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
    }
    button:hover {
      background: #3d5d8b;
    }
    #battle-screen {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.9);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 15;
    }
    #battle-card {
      background: #162342;
      border: 2px solid #77a;
      border-radius: 18px;
      width: 760px;
      max-width: calc(100% - 20px);
      padding: 20px;
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
    }
    .battle-side {
      flex: 1 1 320px;
      min-width: 300px;
      background: rgba(0, 0, 0, 0.2);
      border: 1px solid #446;
      border-radius: 14px;
      padding: 14px;
    }
    .legendary {
      color: gold;
      font-weight: 700;
    }
    .shop-button {
      width: 100%;
      margin-top: 4px;
      text-align: left;
    }
    .health-bar {
      width: 100%;
      height: 12px;
      background: #314862;
      border: 1px solid #57738f;
      border-radius: 7px;
      margin: 8px 0 4px;
      overflow: hidden;
    }
    .health-fill {
      height: 100%;
      background: #59d4a2;
      border-radius: 6px;
      transition: width 0.2s ease;
    }
    .health-fill.low {
      background: #e65a5a;
    }
    .battle-log {
      background: #0f1f33;
      border: 1px solid #446;
      border-radius: 10px;
      min-height: 140px;
      padding: 10px;
      margin-top: 12px;
      overflow-y: auto;
      max-height: 170px;
      font-size: 13px;
      line-height: 1.4;
    }
    .battle-log p {
      margin: 4px 0;
    }
    .battle-switch {
      display: grid;
      gap: 6px;
      margin-top: 10px;
    }
    .party-button {
      width: 100%;
      border: 1px solid #557;
      background: #22375a;
      color: #eef;
      border-radius: 8px;
      padding: 8px;
      cursor: pointer;
      text-align: left;
      font-size: 13px;
    }
    .party-button.active {
      background: #3e6bb3;
      border-color: #87a;
    }
    .party-button.fainted {
      background: #3a2933;
      color: #999;
    }
    #shopPanel {
      display: grid;
      gap: 8px;
    }
  </style>
</head>
