    function currentPet() {
      return playerPets[state.activePetIndex] || playerPets[0];
    }

    function rectangleIntersect(a, b) {
      return !(a.x + a.w < b.x || a.x > b.x + b.w || a.y + a.h < b.y || a.y > b.y + b.h);
    }

    function randomBetween(min, max) {
      return Math.floor(Math.random() * (max - min + 1)) + min;
    }

    function chooseWildTemplate() {
      const total = wildTemplates.reduce((sum, template) => sum + template.spawnWeight, 0);
      let pick = Math.random() * total;
      return wildTemplates.find((template) => {
        pick -= template.spawnWeight;
        return pick <= 0;
      });
    }

    function spawnWild(template) {
      const zone = spawnZones[template.zone || template.type] || spawnZones.grass;
      const spot = zone[Math.floor(Math.random() * zone.length)];
      return {
        name: template.name,
        type: template.type,
        texture: template.texture,
        textureUrl: template.textureUrl,
        level: randomBetween(template.baseLevel, template.maxLevel),
        x: spot.x + randomBetween(0, 24),
        y: spot.y + randomBetween(0, 24),
        w: template.size,
        h: template.size,
        maxHp: template.maxHp,
        hp: template.maxHp,
        attack: template.attack,
        color: template.color,
        legendary: template.legendary,
        mythical: template.mythical || false,
        evolves: template.evolves || [],
      };
    }

    function refillWilds() {
      while (wildAnimals.length < 5) {
