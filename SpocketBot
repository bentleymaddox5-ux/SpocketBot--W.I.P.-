const isMobile = window.innerWidth < 768 || /Mobi|Android/i.test(navigator.userAgent);
const saveKey = isMobile ? 'petAdventure_mobile' : 'petAdventure_desktop';

function saveGame() {
  localStorage.setItem(saveKey, JSON.stringify({
    playerPets,
    money: state.money,
    balls: state.balls,
    activePetIndex: state.activePetIndex
  }));
}

function loadGame() {
  const data = localStorage.getItem(saveKey);
  if (data) {
    try {
      const parsed = JSON.parse(data);
      playerPets = parsed.playerPets || [];
      state.money = parsed.money || 120;
      state.balls = parsed.balls || { standard: 5, great: 0, ultra: 0 };
      state.activePetIndex = parsed.activePetIndex || 0;
    } catch (e) {
      console.error('Failed to load save data', e);
    }
  }
}

