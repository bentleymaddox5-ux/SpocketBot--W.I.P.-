                if (
                  (e.target === accessCodeInput) ||
                  (e.target === accessCodeBtn) ||
                  (e.target.closest && e.target.closest('#codeGate'))
                ) {
                  return;
                }
                e.stopPropagation();
                e.preventDefault();
                return false;
              }
            }
            // Block pointer and keyboard events on the whole document when codeGate is open
            ['keydown','keyup','mousedown','mouseup','click','touchstart','touchend','wheel'].forEach(evt => {
              document.addEventListener(evt, blockBackground, true);
