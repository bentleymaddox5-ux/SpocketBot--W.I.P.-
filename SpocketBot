      gameStateEl.textContent = state.mode === 'explore' ? 'Explore' : 'Battle';
      messageEl.textContent = state.message;
      // Add event listener for the input
      const input = document.getElementById('textureUrlInput');
      if (input) {
        input.addEventListener('change', (e) => {
          setTextureUrl(e.target.value);
        });
      }
    }

    function setTextureUrl(url) {
      const pet = currentPet();
      if (pet) {
        pet.textureUrl = url;
        saveGame();
      }
    }

    function updateBattleUi() {
      if (!state.wild) return;
      const wild = state.wild;
      const pet = currentPet();
      wildInfoEl.innerHTML = `
        <p>${wild.legendary ? '<span class="legendary">★ Legendary ★</span>' : ''}<strong>${wild.name}</strong> (Lv ${wild.level})</p>
        <p>Type: ${wild.type}${wild.mythical ? ' Mythical' : ''}</p>
        ${createHealthBar(Math.max(0, wild.hp), wild.maxHp)}
      `;
      battlePetInfoEl.innerHTML = `
        <p><strong>${pet.name}</strong> (Lv ${pet.level})</p>
        <p>Attack: ${pet.attack}</p>
        ${createHealthBar(pet.hp, pet.maxHp)}
      `;
      turnInfoEl.textContent = state.turn === 'player' ? 'Turn: Your Spocketbot' : 'Turn: Opponent';
      updateBattleLog();
      renderBattleSwitch();
      updatePetUi();
    }

    function addBattleLog(message) {
      state.battleLog.unshift(message);
      if (state.battleLog.length > 6) state.battleLog.pop();
    }

    function updateBattleLog() {
      if (!battleLogEl) return;
      battleLogEl.innerHTML = state.battleLog
        .map((entry) => `<p>${entry}</p>`)
        .join('');
    }

    function renderBattleSwitch() {
      if (!battleSwitchEl) return;
      if (playerPets.length <= 1) {
        battleSwitchEl.innerHTML = '<p style="margin:0; font-size:13px;">Capture more pets to switch during battle.</p>';
        return;
      }
      battleSwitchEl.innerHTML = playerPets
        .map((pet, index) => {
          const active = index === state.activePetIndex;
          const fainted = pet.hp <= 0;
          const label = `${pet.name} Lv ${pet.level}${active ? ' (Active)' : ''}${fainted ? ' - Fainted' : ''}`;
          return `<button class="party-button ${active ? 'active' : ''} ${fainted ? 'fainted' : ''}" data-index="${index}" ${active || fainted ? 'disabled' : ''}>${label}</button>`;
        })
        .join('');
    }

    function switchPet(index) {
      if (state.mode !== 'battle') return;
      if (state.activePetIndex === index) return;
      const pet = playerPets[index];
      if (!pet || pet.hp <= 0) {
        state.message = 'Cannot switch to a fainted Spocketbot.';
        updateBattleUi();
        return;
      }
      state.activePetIndex = index;
      state.turn = 'wild';
      state.message = `Switched to ${pet.name}!`;
      addBattleLog(`Switched to ${pet.name}!`);
      updateBattleUi();
      window.setTimeout(() => {
        if (state.mode === 'battle' && state.turn === 'wild') wildAttack();
      }, 700);
    }

    function checkHealStation() {
      const station = healStations.find((s) => rectangleIntersect(player, s));
      if (station) {
        const pet = currentPet();
        if (pet && pet.hp < pet.maxHp) {
          pet.hp = pet.maxHp;
          state.message = `${pet.name} is fully healed!`;
          updatePetUi();
        }
      }
    }

    function findWildCollision() {
      return wildAnimals.find((wild) => rectangleIntersect(player, wild));
    }

    function startBattle(wild) {
      const pet = currentPet();
      if (!pet || pet.hp <= 0) {
        state.message = `${pet ? pet.name : 'No pet'} is fainted! Heal it before fighting.`;
        updatePetUi();
        return;
      }
      state.mode = 'battle';
      state.wild = wild;
      state.turn = 'player';
      state.battleLog = [`A wild ${wild.name} appeared!`];
      state.message = `A wild ${wild.name} appeared!`;
      battleScreen.style.display = 'flex';
      updateBattleUi();
    }

    function endBattle(message) {
      state.mode = 'explore';
      state.wild = null;
      // preserve battle result message and append auto-heal notice
      const pet = currentPet();
      if (pet) {
        pet.hp = pet.maxHp;
        state.message = `${message} ${pet.name} was healed after the battle.`;
      } else {
        state.message = message;
      }
      battleScreen.style.display = 'none';
      updatePetUi();
      saveGame();
    }

    function gainExp(amount) {
      const pet = currentPet();
      pet.exp += amount;
      let required = pet.level * 10;
      while (pet.exp >= required) {
        pet.exp -= required;
        pet.level += 1;
        pet.maxHp += 8;
        pet.attack += 2;
        pet.hp = Math.min(pet.hp + 12, pet.maxHp);
        state.message = `${pet.name} reached level ${pet.level}!`;
        checkEvolution();
        required = pet.level * 10;
      }
    }

    function showEvolutionPopup(pet) {
      const popup = document.getElementById('evolutionPopup');
      const spriteDiv = document.getElementById('evolutionSprite');
      const nameDiv = document.getElementById('evolutionName');
      if (!popup || !spriteDiv || !nameDiv) return;
      // Draw the evolved pet's sprite
      let imgHtml = '';
      if (pet.textureUrl) {
        imgHtml = `<img src="${pet.textureUrl}" alt="${pet.name}" style="width:120px; height:120px; image-rendering:pixelated; border-radius:16px; background:#fff;">`;
      } else {
        imgHtml = `<div style="width:120px; height:120px; background:#fff; border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:2em; color:#333;">?</div>`;
      }
      spriteDiv.innerHTML = imgHtml;
      nameDiv.textContent = pet.name;
      popup.style.display = 'flex';
      // Hide popup on button click
      const closeBtn = document.getElementById('closeEvolutionBtn');
      if (closeBtn) {
        closeBtn.onclick = () => { popup.style.display = 'none'; updatePetUi(); };
      }
    }

    function checkEvolution() {
      const pet = currentPet();
      const nextStage = pet.evolves[pet.stage - 1];
      if (nextStage && pet.level >= nextStage.level) {
        pet.name = nextStage.name;
        pet.maxHp = nextStage.maxHp;
        pet.attack = nextStage.attack;
        pet.texture = nextStage.texture || pet.texture;
        pet.textureUrl = nextStage.textureUrl || pet.textureUrl;
        pet.hp = pet.maxHp;
        pet.stage += 1;
        state.message = `${pet.name} evolved at level ${pet.level}!`;
        showEvolutionPopup(pet);
      }
    }

    function calculateDamage(attacker) {
      return Math.max(1, Math.floor(attacker.attack + attacker.level * 0.8 + Math.random() * (attacker.level / 2 + 1)));
    }

    function playerAttack() {
      if (state.turn !== 'player' || !state.wild) {
        state.message = 'Wait for your turn.';
        updateBattleUi();
        return;
      }
      const pet = currentPet();
      const wild = state.wild;
      const damage = calculateDamage(pet);
      wild.hp -= damage;
      const msg = `${pet.name} dealt ${damage} damage to ${wild.name}.`;
      state.message = msg;
      addBattleLog(msg);
      updateBattleUi();
      if (wild.hp <= 0) {
        awardBattleRewards(wild, false);
        gainExp(wild.level * 6); // Grant EXP for defeating wild pet
        wildAnimals.splice(wildAnimals.indexOf(wild), 1);
        addBattleLog(`You defeated ${wild.name}!`);
        endBattle(`You defeated ${wild.name}!`);
        spawnAfterDelay();
        return;
      }
      state.turn = 'wild';
      updateBattleUi();
      window.setTimeout(() => {
        if (state.mode === 'battle' && state.turn === 'wild') wildAttack();
      }, 700);
    }

    function awardBattleRewards(wild, captured) {
      const reward = wild.level * (captured ? 14 : 8);
      state.money += reward;
      state.message = `Earned $${reward} from ${captured ? 'capture' : 'defeat'}!`;
      updatePetUi();
      saveGame();
    }

    function wildAttack() {
      if (!state.wild || state.turn !== 'wild') return;
      const pet = currentPet();
      const wild = state.wild;
      const damage = calculateDamage(wild);
      pet.hp -= damage;
      const msg = `${wild.name} hit ${pet.name} for ${damage}.`;
      state.message = msg;
      addBattleLog(msg);
      if (pet.hp <= 0) {
        pet.hp = 0;
        endBattle(`${pet.name} fainted! Return to a heal station.`);
        spawnAfterDelay();
        return;
      }
      state.turn = 'player';
      updateBattleUi();
    }

    function throwPokeball() {
      if (state.turn !== 'player' || !state.wild) {
        state.message = 'You can only throw a ball on your turn.';
        updateBattleUi();
        return;
      }
      const selected = ballSelect.value;
      if (state.balls[selected] <= 0) {
        state.message = `No ${ballTypes[selected].label}s left!`;
        updateBattleUi();
        return;
      }
      state.balls[selected] -= 1;
      const wild = state.wild;
      const baseChance = 0.18 + (currentPet().level - wild.level) * 0.02;
      const typeBonus = ballTypes[selected].typeBonus[wild.type] || 1;
      const rarePenalty = wild.mythical ? 2.3 : wild.legendary ? 1.7 : 1;
      const luck = ballTypes[selected].multiplier * typeBonus;
      const chance = Math.min(Math.max(baseChance * luck / rarePenalty, 0.03), 0.82);
      const success = Math.random() < chance;
      if (success) {
        awardBattleRewards(wild, true);
        state.message = `Captured ${wild.name}!`;
        addBattleLog(`Captured ${wild.name}!`);
        playerPets.push({
          name: wild.name,
          level: wild.level,
          exp: 0,
          stage: 1,
          maxHp: wild.maxHp,
          hp: wild.maxHp,
          attack: wild.attack,
          w: wild.w,
          h: wild.h,
          texture: wild.texture,
          textureUrl: wild.textureUrl,
          evolves: wild.evolves,
          isLegendary: wild.legendary,
        });
        wildAnimals.splice(wildAnimals.indexOf(wild), 1);
        endBattle(`You captured ${wild.name}!`);
        spawnAfterDelay();
      } else {
        state.message = `${wild.name} broke free!`;
        addBattleLog(`${wild.name} broke free!`);
        state.turn = 'wild';
        updateBattleUi();
        window.setTimeout(() => {
          if (state.mode === 'battle' && state.turn === 'wild') wildAttack();
        }, 700);
      }
    }

    function tryRun() {
      if (state.turn !== 'player') {
        state.message = 'You can only run on your turn.';
        updateBattleUi();
        return;
      }
      if (Math.random() < 0.6) {
        addBattleLog('You successfully ran away.');
        endBattle('You successfully ran away.');
      } else {
        state.message = 'Escape failed!';
        addBattleLog('Escape failed!');
        state.turn = 'wild';
        updateBattleUi();
        window.setTimeout(() => {
          if (state.mode === 'battle' && state.turn === 'wild') wildAttack();
        }, 700);
      }
    }

    function handleExploration() {
      let dx = 0;
      let dy = 0;
      if (keys['w']) dy -= player.speed;
      if (keys['s']) dy += player.speed;
      if (keys['a']) dx -= player.speed;
      if (keys['d']) dx += player.speed;
      player.x = Math.max(16, Math.min(canvas.width - player.w - 16, player.x + dx));
      player.y = Math.max(16, Math.min(canvas.height - player.h - 16, player.y + dy));
      if (dx !== 0 || dy !== 0) console.log('player moved', player.x, player.y, 'dx', dx, 'dy', dy);
      checkHealStation();
      const pet = currentPet();
      if (pet && pet.hp <= 0) {
        state.message = `${pet.name} is fainted! Heal it before fighting.`;
        updatePetUi();
      }
      const wild = findWildCollision();
      if (wild) {
        if (pet && pet.hp <= 0) {
          // Allow movement but prevent starting a battle when your active pet is fainted
          state.message = `${pet.name} is fainted! Return to a heal station.`;
          updatePetUi();
        } else {
          startBattle(wild);
        }
      }
    }

    function drawRect(x, y, w, h, color) {
      ctx.fillStyle = color;
      ctx.fillRect(x, y, w, h);
    }

    function drawText(text, x, y, color = '#eef', size = '14px') {
      ctx.fillStyle = color;
      ctx.font = `${size} Arial, sans-serif`;
      ctx.fillText(text, x, y);
    }

    const textureDrawers = {
      flarecub(entity, x, y, s = 1) {
        ctx.fillStyle = '#e15210';
        ctx.fillRect(x + 4 * s, y + 4 * s, 8 * s, 5 * s);
        ctx.fillStyle = '#f2975d';
        ctx.fillRect(x + 5 * s, y + 9 * s, 6 * s, 4 * s);
        ctx.fillStyle = '#000';
        ctx.fillRect(x + 6 * s, y + 5 * s, 2 * s, 2 * s);
        ctx.fillRect(x + 10 * s, y + 5 * s, 2 * s, 2 * s);
        ctx.fillStyle = '#ff8c00';
        ctx.fillRect(x + 12 * s, y + 1 * s, 4 * s, 10 * s);
      },
      flareling(entity, x, y, s = 1) {
        ctx.fillStyle = '#ff5722';
        ctx.fillRect(x + 4 * s, y + 4 * s, 10 * s, 6 * s);
        ctx.fillStyle = '#ffab91';
        ctx.fillRect(x + 5 * s, y + 10 * s, 8 * s, 4 * s);
        ctx.fillStyle = '#000';
        ctx.fillRect(x + 6 * s, y + 5 * s, 2 * s, 2 * s);
        ctx.fillRect(x + 10 * s, y + 5 * s, 2 * s, 2 * s);
        ctx.fillStyle = '#ff9800';
        ctx.fillRect(x + 14 * s, y + 1 * s, 4 * s, 12 * s);
      },
      blazewolf(entity, x, y, s = 1) {
        ctx.fillStyle = '#d84315';
        ctx.fillRect(x + 3 * s, y + 4 * s, 14 * s, 8 * s);
        ctx.fillStyle = '#ff8a65';
        ctx.fillRect(x + 4 * s, y + 12 * s, 10 * s, 4 * s);
        ctx.fillStyle = '#000';
        ctx.fillRect(x + 6 * s, y + 5 * s, 2 * s, 2 * s);
        ctx.fillRect(x + 10 * s, y + 5 * s, 2 * s, 2 * s);
        ctx.fillStyle = '#ff5722';
        ctx.fillRect(x + 16 * s, y + 1 * s, 4 * s, 14 * s);
      },
      leafmouse(entity, x, y, s = 1) {
        ctx.fillStyle = '#86c57a';
        ctx.fillRect(x + 5 * s, y + 5 * s, 10 * s, 10 * s);
        ctx.fillStyle = '#b7f08f';
        ctx.fillRect(x + 4 * s, y + 2 * s, 4 * s, 4 * s);
        ctx.fillRect(x + 14 * s, y + 2 * s, 4 * s, 4 * s);
        ctx.fillStyle = '#2d5f2f';
        ctx.fillRect(x + 7 * s, y + 8 * s, 2 * s, 2 * s);
        ctx.fillRect(x + 11 * s, y + 8 * s, 2 * s, 2 * s);
      },
      stoneclaw(entity, x, y, s = 1) {
        ctx.fillStyle = '#a49a7a';
        ctx.fillRect(x + 5 * s, y + 4 * s, 12 * s, 10 * s);
        ctx.fillStyle = '#7b6f54';
        ctx.fillRect(x + 7 * s, y + 8 * s, 4 * s, 3 * s);
        ctx.fillStyle = '#766a4c';
        ctx.fillRect(x + 3 * s, y + 10 * s, 5 * s, 2 * s);
      },
      aqualoon(entity, x, y, s = 1) {
        ctx.fillStyle = '#6ec0ff';
        ctx.fillRect(x + 3 * s, y + 6 * s, 14 * s, 7 * s);
        ctx.fillStyle = '#4a9fff';
        ctx.fillRect(x + 11 * s, y + 4 * s, 5 * s, 5 * s);
        ctx.fillStyle = '#1f5a7f';
        ctx.fillRect(x + 6 * s, y + 8 * s, 4 * s, 2 * s);
      },
      skyflare(entity, x, y, s = 1) {
        ctx.fillStyle = '#f6df2d';
        ctx.fillRect(x + 3 * s, y + 4 * s, 16 * s, 10 * s);
        ctx.fillStyle = '#ff9e00';
        ctx.fillRect(x + 11 * s, y + 1 * s, 5 * s, 9 * s);
        ctx.fillStyle = '#d95c00';
        ctx.fillRect(x + 7 * s, y + 11 * s, 2 * s, 3 * s);
      },
      aetherion(entity, x, y, s = 1) {
        ctx.fillStyle = '#b97dfb';
        ctx.fillRect(x + 3 * s, y + 4 * s, 16 * s, 10 * s);
        ctx.fillStyle = '#7a3fff';
        ctx.fillRect(x + 6 * s, y + 2 * s, 6 * s, 5 * s);
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(x + 9 * s, y + 8 * s, 2 * s, 2 * s);
      },
      leafcat(entity, x, y, s = 1) {
        ctx.fillStyle = '#4caf50';
        ctx.fillRect(x + 5 * s, y + 5 * s, 12 * s, 10 * s);
        ctx.fillStyle = '#81c784';
        ctx.fillRect(x + 3 * s, y + 2 * s, 6 * s, 4 * s);
        ctx.fillRect(x + 13 * s, y + 2 * s, 6 * s, 4 * s);
        ctx.fillStyle = '#388e3c';
        ctx.fillRect(x + 8 * s, y + 8 * s, 2 * s, 2 * s);
        ctx.fillRect(x + 12 * s, y + 8 * s, 2 * s, 2 * s);
      },
      stonebeast(entity, x, y, s = 1) {
        ctx.fillStyle = '#8d6e63';
        ctx.fillRect(x + 4 * s, y + 4 * s, 14 * s, 12 * s);
        ctx.fillStyle = '#5d4037';
        ctx.fillRect(x + 6 * s, y + 8 * s, 6 * s, 4 * s);
        ctx.fillStyle = '#a1887f';
        ctx.fillRect(x + 2 * s, y + 10 * s, 6 * s, 3 * s);
        ctx.fillRect(x + 14 * s, y + 10 * s, 6 * s, 3 * s);
      },
      aquaking(entity, x, y, s = 1) {
        ctx.fillStyle = '#2196f3';
        ctx.fillRect(x + 3 * s, y + 5 * s, 16 * s, 10 * s);
        ctx.fillStyle = '#1976d2';
        ctx.fillRect(x + 6 * s, y + 2 * s, 6 * s, 5 * s);
        ctx.fillStyle = '#0d47a1';
        ctx.fillRect(x + 8 * s, y + 8 * s, 2 * s, 2 * s);
        ctx.fillRect(x + 12 * s, y + 8 * s, 2 * s, 2 * s);
      },
    };

    const textureImages = {};

    function getTextureImage(url) {
      if (!textureImages[url]) {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.src = url;
        textureImages[url] = img;
      }
      return textureImages[url];
    }

    function drawMap() {
      tiles.forEach((tile) => drawRect(tile.x, tile.y, tile.w, tile.h, tile.color));
      pathRects.forEach((path) => drawRect(path.x, path.y, path.w, path.h, '#8f6f48'));
      healStations.forEach((st) => {
        drawRect(st.x, st.y, st.w, st.h, '#29c47a');
        drawText('HEAL', st.x + 8, st.y + 36, '#fff', '14px');
      });
      drawRect(0, 0, 800, 16, '#1d2740');
      drawRect(0, 484, 800, 16, '#1d2740');
      drawRect(0, 0, 16, 500, '#1d2740');
      drawRect(784, 0, 16, 500, '#1d2740');
    }

    function drawPlayerSprite(x, y) {
      ctx.save();
      ctx.translate(x, y);
      if (!player.img && player.textureUrl) {
        player.img = new window.Image();
        player.img.src = player.textureUrl;
      }
      if (player.img && player.img.complete && player.img.naturalWidth) {
        ctx.drawImage(player.img, -player.w/2, -player.h/2, player.w, player.h);
      } else {
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(6, 2, 12, 12);
        ctx.fillStyle = '#000000';
        ctx.fillRect(6, 14, 12, 12);
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(8, 4, 4, 4);
        ctx.fillStyle = '#000000';
        ctx.fillRect(10, 6, 2, 2);
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(4, 20, 6, 4);
        ctx.fillRect(14, 20, 6, 4);
      }
      ctx.restore();
    }

    function drawPetSprite(entity, x, y, scale = 1) {
      const s = scale;
      if (entity.drawSprite) {
        entity.drawSprite(entity, x, y, s);
        return;
      }
      const textureKey = entity.texture;
      const textureUrl = entity.textureUrl || (typeof textureKey === 'string' && /^https?:\/\//.test(textureKey) ? textureKey : null);
      if (textureUrl) {
        const img = getTextureImage(textureUrl);
        if (img.complete && img.naturalWidth) {
          ctx.drawImage(img, x, y, entity.w || 24, entity.h || 24);
          return;
        }
      }
      if (textureKey && textureDrawers[textureKey]) {
        textureDrawers[textureKey](entity, x, y, s);
        return;
      }
      if (entity.type === 'grass') {
        ctx.fillStyle = '#6ecb6d';
        ctx.fillRect(x + 4 * s, y + 6 * s, 10 * s, 7 * s);
        ctx.fillStyle = '#3b7f3b';
        ctx.fillRect(x + 6 * s, y + 2 * s, 6 * s, 5 * s);
      } else if (entity.type === 'rock') {
        ctx.fillStyle = '#a49a7a';
        ctx.fillRect(x + 5 * s, y + 4 * s, 12 * s, 10 * s);
        ctx.fillStyle = '#7b6f54';
        ctx.fillRect(x + 7 * s, y + 8 * s, 4 * s, 3 * s);
      } else if (entity.type === 'water') {
        ctx.fillStyle = '#6ec0ff';
        ctx.fillRect(x + 3 * s, y + 6 * s, 14 * s, 7 * s);
        ctx.fillStyle = '#4a9fff';
        ctx.fillRect(x + 11 * s, y + 4 * s, 5 * s, 5 * s);
      } else if (entity.legendary) {
        ctx.fillStyle = '#f6df2d';
        ctx.fillRect(x + 3 * s, y + 4 * s, 16 * s, 10 * s);
        ctx.fillStyle = '#ff9e00';
        ctx.fillRect(x + 11 * s, y + 1 * s, 5 * s, 9 * s);
      } else {
        ctx.fillStyle = entity.color || '#ddd';
        ctx.fillRect(x + 5 * s, y + 5 * s, 10 * s, 10 * s);
      }
    }

    function drawGame() {
      // Always schedule the next frame so rendering resumes after battle
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      if (state.mode === 'explore') {
        drawMap();
        wildAnimals.forEach((wild) => {
          drawPetSprite(wild, wild.x, wild.y, 1);
          drawText(`${wild.name} Lv ${wild.level}`, wild.x - 6, wild.y - 6, '#fff', '12px');
        });
        drawPlayerSprite(player.x, player.y);
      }
      requestAnimationFrame(drawGame);
    }

    function spawnAfterDelay() {
      window.setTimeout(() => {
        refillWilds();
      }, 1200);
    }

    attackBtn.addEventListener('click', () => {
      if (state.mode === 'battle' && state.wild) playerAttack();
    });
    pokeballBtn.addEventListener('click', () => {
      if (state.mode === 'battle' && state.wild) throwPokeball();
    });
    runBtn.addEventListener('click', () => {
      if (state.mode === 'battle') tryRun();
    });

    document.addEventListener('keydown', (event) => {
      keys[event.key.toLowerCase()] = true;
      console.log('keydown', event.key.toLowerCase());
      if (state.mode === 'explore' && ['w', 'a', 's', 'd'].includes(event.key.toLowerCase())) {
        event.preventDefault();
      }
    });

    document.addEventListener('keyup', (event) => {
      keys[event.key.toLowerCase()] = false;
      console.log('keyup', event.key.toLowerCase());
    });

    shopPanel.addEventListener('click', (event) => {
      const button = event.target.closest('button[data-ball]');
      if (!button) return;
      const ballKey = button.dataset.ball;
      const cost = ballTypes[ballKey].price;
      if (state.money < cost) {
        state.message = `Not enough money for ${ballTypes[ballKey].label}.`;
        updatePetUi();
        return;
      }
      state.money -= cost;
      state.balls[ballKey] += 1;
      state.message = `Bought 1 ${ballTypes[ballKey].label}.`;
      updatePetUi();
      saveGame();
    });

    battleSwitchEl.addEventListener('click', (e) => {
      if (e.target.classList.contains('party-button') && !e.target.disabled) {
        const index = parseInt(e.target.dataset.index);
        switchPet(index);
      }
    });

    document.getElementById('chooseFlarecub').addEventListener('click', () => chooseStarter('flarecub'));
    document.getElementById('chooseLeafmouse').addEventListener('click', () => chooseStarter('leafmouse'));
    document.getElementById('chooseStoneclaw').addEventListener('click', () => chooseStarter('stoneclaw'));

    function gameLoop() {
      if (state.mode === 'explore') {
        handleExploration();
      }
      requestAnimationFrame(gameLoop);
    }

    function startGame() {
      refillWilds();
      state.mode = 'explore';
      state.message = 'Use W A S D to move around.';
      gameLoop();
    }

    function chooseStarter(key) {
      playerPets = [starterOptions[key]];
      document.getElementById('starterSelection').style.display = 'none';
      startGame();
      saveGame();
    }

    function init() {
      loadGame();
      if (playerPets.length === 0) {
        document.getElementById('starterSelection').style.display = 'block';
        state.message = 'Choose your starter Spocketbot.';
      } else {
        startGame();
      }
      updateShopUi();
      updatePetUi();
      drawGame();
    }

    init();
  </script>
</body>
</html>
